---
layout: base.njk
eleventyComputed:
  title: "{{ pages.filosofi.title }}"
  description: "{{ pages.filosofi.description }}"
  ogTitle: "{{ pages.filosofi.ogTitle }}"
  ogDescription: "{{ pages.filosofi.ogDescription }}"
canonical: "https://emilsalzer.dk/filosofi/"
ogUrl: "https://emilsalzer.dk/filosofi/"
ogImage: "https://emilsalzer.dk/assets/images/forside-1.jpg"
extraHead: |
  <style>
      .page-hero { text-align: center; padding: 48px 48px 32px; }
      .page-hero h1 { font-size: clamp(48px, 6vw, 72px); font-weight: 700; line-height: 1.1; }

      .content {
          max-width: 680px;
          margin: 0 auto;
          padding: 0 48px 80px;
      }
      .content p {
          margin-bottom: 20px;
          font-size: 16px;
          line-height: 1.8;
      }
      .content blockquote {
          font-style: italic;
          padding: 0;
          margin: 24px 0;
          color: var(--black);
          font-size: 16px;
          line-height: 1.8;
      }
      .content h2 {
          font-size: clamp(28px, 3.5vw, 36px);
          font-weight: 700;
          margin: 56px 0 20px;
          line-height: 1.2;
      }
      .content a {
          color: var(--black);
          font-weight: 700;
      }

      .video-container {
          position: relative;
          width: 100%;
          padding-bottom: 56.25%;
          margin: 32px 0 48px;
          background: #000;
      }
      .video-container iframe {
          position: absolute;
          top: 0; left: 0;
          width: 100%; height: 100%;
          border: none;
      }

      @media (max-width: 900px) {
          .page-hero { padding: 32px 24px 24px; }
          .content { padding: 0 24px 60px; }
      }
  </style>
---

<section class="page-hero" data-reveal>
    <h1>{{ pages.filosofi.heading }}</h1>
</section>

<div class="content" data-reveal>
    {{ pages.filosofi.body | safe }}
</div>
