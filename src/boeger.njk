---
layout: base.njk
eleventyComputed:
  title: "{{ pages.boeger.title }}"
  description: "{{ pages.boeger.description }}"
  ogTitle: "{{ pages.boeger.ogTitle }}"
  ogDescription: "{{ pages.boeger.ogDescription }}"
canonical: "https://emilsalzer.dk/boeger/"
ogUrl: "https://emilsalzer.dk/boeger/"
ogImage: "https://emilsalzer.dk/assets/images/boeger/kaosviol.jpg"
extraHead: |
  <style>
      .books-header {
          text-align: center;
          padding: 60px 48px 40px;
      }
      .books-header h1 {
          font-size: clamp(48px, 6vw, 72px);
          font-weight: 700;
          line-height: 1.1;
      }
      .books-grid {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 48px 40px;
          max-width: 800px;
          margin: 0 auto;
          padding: 0 48px 80px;
      }
      .book-card {
          display: block;
          color: var(--black);
          text-decoration: none;
          transition: opacity 0.2s;
      }
      .book-card:hover {
          opacity: 0.8;
      }
      .book-meta {
          font-size: 14px;
          color: var(--grey);
          margin-bottom: 12px;
          text-align: center;
      }
      .book-meta strong {
          color: var(--black);
      }
      .book-cover {
          width: 100%;
          height: auto;
          display: block;
      }

      @media (max-width: 600px) {
          .books-header { padding: 40px 24px 24px; }
          .books-grid {
              grid-template-columns: 1fr;
              gap: 40px;
              padding: 0 24px 60px;
              max-width: 400px;
          }
      }
  </style>
---

<section class="books-header" data-reveal>
    <h1>{{ pages.boeger.heading }}</h1>
</section>

<div class="books-grid">
    {% for book in pages.boeger.books %}
    <a href="{{ book.link }}" class="book-card" data-reveal>
        <p class="book-meta"><strong>{{ book.year }}</strong> / {{ book.title }}</p>
        <img src="{{ book.image }}" alt="{{ book.alt }}" class="book-cover" loading="lazy">
    </a>
    {% endfor %}
</div>
